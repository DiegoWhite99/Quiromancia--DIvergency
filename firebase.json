{
  "hosting": {
    "site": "quiromacia-ia",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": { "functionId": "quiromanciaApi", "region": "us-central1" } }
    ],
    "headers": [
      {
        "source": "**/*.@(mp3|wav|m4a)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
